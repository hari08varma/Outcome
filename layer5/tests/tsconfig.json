{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "types": [
            "node"
        ],
        "baseUrl": ".",
        "paths": {
            "vitest": [
                "../api/node_modules/vitest"
            ]
        }
    },
    "include": [
        "./**/*.ts"
    ]
}
