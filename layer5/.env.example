# ════════════════════════════════════════
# REQUIRED — API will not start without these
# ════════════════════════════════════════

# Supabase project URL
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (bypasses RLS)
# NEVER expose this in client-side code or logs
# Get from: Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase anonymous key (safe for client-side)
# Get from: Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY=your_anon_key_here

# Internal Edge Function & API Secret
# Generate with: openssl rand -hex 32
LAYERINFINITE_INTERNAL_SECRET=your_internal_secret_here

# Development-only API key bypass (generate: openssl rand -hex 16)
# ONLY active when NODE_ENV=development AND LAYERINFINITE_DEV_BYPASS=true
# Never set this in production — server will crash if you try
LAYERINFINITE_DEV_API_KEY=your_32_byte_hex_string_here

# Node environment
NODE_ENV=development

# CORS allowed origins (comma-separated)
# Must include your dashboard URL exactly
# Example: https://your-app.vercel.app,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ════════════════════════════════════════
# REQUIRED for dashboard
# ════════════════════════════════════════

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Layerinfinite API URL (for simulate page)
VITE_LAYERINFINITE_API_URL=http://localhost:3000

# ════════════════════════════════════════
# OPTIONAL but recommended
# ════════════════════════════════════════

# Sentry DSN for error monitoring
# Get from: sentry.io → New Project → DSN
# Leave empty to disable error monitoring
SENTRY_DSN=
VITE_SENTRY_DSN=

# Resend API key for email notifications
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.dev

# Embedding Provider (supabase or openai)
EMBEDDING_PROVIDER=supabase
# Only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Port for API server (default: 3000)
API_PORT=3000

# API Cache Refresh URL
API_CACHE_REFRESH_URL=http://localhost:3000/internal/refresh-score-cache

# Training pipeline webhook URL
TRAINING_WEBHOOK_URL=

# ════════════════════════════════════════
# DEV BYPASS (Never True in Production)
# ════════════════════════════════════════
LAYERINFINITE_DEV_BYPASS=false
DEV_CUSTOMER_ID=a0000000-0000-0000-0000-000000000001
DEV_AGENT_ID=d0000000-0000-0000-0000-000000000001

# ════════════════════════════════════════
# Supabase Edge Function secrets
# Set via: supabase secrets set KEY=value
# NOT in .env (edge functions use Deno.env)
# ════════════════════════════════════════
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# RESEND_API_KEY (if using email notifications)
# ALERT_FROM_EMAIL
# DASHBOARD_URL
# API_CACHE_REFRESH_URL
