# Supabase project URL
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://fakomwsewdxazaqawjuv.supabase.co

# Supabase service role key (bypasses RLS)
# NEVER expose this in client-side code or logs
# Get from: Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZha29td3Nld2R4YXphcWF3anV2Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjY5MTk1NywiZXhwIjoyMDg4MjY3OTU3fQ.T4NK919YFRO6zhHeFb2lEoKo0cvE5oERKgtsrSEJVto"

# Supabase anonymous key (safe for client-side)
# Get from: Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZha29td3Nld2R4YXphcWF3anV2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI2OTE5NTcsImV4cCI6MjA4ODI2Nzk1N30.h-alSOeQBP92q3QHzgetG0tF602h_A76e0n_ORUfSkE"

# Internal Edge Function & API Secret
# Generate with: openssl rand -hex 32
# Internal cron/admin secret (generate: openssl rand -hex 32)
# Used ONLY for POST /internal/refresh-score-cache
# NEVER use this as an API key — it bypasses all tenant isolation
LAYERINFINITE_INTERNAL_SECRET=

# Development-only API key bypass (generate: openssl rand -hex 16)  
# ONLY active when NODE_ENV=development AND LAYERINFINITE_DEV_BYPASS=true
# Never set this in production — server will crash if you try
LAYERINFINITE_DEV_API_KEY="your_32_byte_hex_string_here"

# Node environment
NODE_ENV=development

# CORS allowed origins (comma-separated)
# Must include your dashboard URL exactly
# Example: https://layerinfinite.vercel.app,https://app.layerinfinite.dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ════════════════════════════════════════
# REQUIRED for dashboard
# ════════════════════════════════════════

VITE_SUPABASE_URL=https://fakomwsewdxazaqawjuv.supabase.co
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZha29td3Nld2R4YXphcWF3anV2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI2OTE5NTcsImV4cCI6MjA4ODI2Nzk1N30.h-alSOeQBP92q3QHzgetG0tF602h_A76e0n_ORUfSkE"

# Layerinfinite API URL (for simulate page)
VITE_LAYERINFINITE_API_URL=http://localhost:3000

# ════════════════════════════════════════
# OPTIONAL but recommended
# ════════════════════════════════════════

# Sentry DSN for error monitoring
# Get from: sentry.io → New Project → DSN
# Leave empty to disable error monitoring
SENTRY_DSN=
VITE_SENTRY_DSN=

# Resend API key for email notifications
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@layerinfinite.dev

# Embedding Provider (supabase or openai)
EMBEDDING_PROVIDER=supabase
# Only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# Port for API server (default: 3000)
API_PORT=3000

# Supabase Pooler URL (for direct pg connections)
# DATABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# API Cache Refresh URL (used by Edge Functions to clear Node.js memory cache)
API_CACHE_REFRESH_URL=http://localhost:3000/internal/refresh-score-cache

# Training pipeline webhook URL
# Set to Cloud Run job trigger URL to enable remote training 
# from /v1/admin/trigger-training
TRAINING_WEBHOOK_URL=

# ════════════════════════════════════════
# DEV BYPASS (Never True in Production)
# ════════════════════════════════════════
LAYERINFINITE_DEV_BYPASS=false
DEV_CUSTOMER_ID=a0000000-0000-0000-0000-000000000001
DEV_AGENT_ID=d0000000-0000-0000-0000-000000000001

# ════════════════════════════════════════
# Supabase Edge Function secrets
# Set via: supabase secrets set KEY=value
# NOT in .env (edge functions use Deno.env)
# ════════════════════════════════════════
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# RESEND_API_KEY (if using email notifications)
# ALERT_FROM_EMAIL
# DASHBOARD_URL
# API_CACHE_REFRESH_URL
