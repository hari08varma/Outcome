{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "https://outcome-green.vercel.app/auth?mode=login"
    },
    {
      "source": "/signup",
      "destination": "https://outcome-green.vercel.app/auth?mode=signup"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://outcome-green.vercel.app/dashboard/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
